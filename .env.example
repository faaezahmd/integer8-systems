# Resend (https://resend.com) — required for the contact form
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional. Until you verify a domain in Resend, leave CONTACT_FROM_EMAIL unset
# to use Resend's onboarding sender (delivers only to your account email).
# Once a domain is verified, set this to an address on it:
# CONTACT_FROM_EMAIL="Integer8 Systems <hello@integer8systems.com>"

# Optional. Where contact submissions are delivered. Defaults to site.email.
# CONTACT_TO_EMAIL=hello@integer8systems.com
